# Bot directive — migrated from SCM on 2026-04-17
# Media-Type: application/vnd.bot-directive+a2ml

schema_version = "1.0"
directive_type = "bot-directive"
bot = "glambot"
scope = "presentation + accessibility"
allow = ["docs", "readme badges", "ui/accessibility suggestions"]
deny = ["logic changes"]
notes = "Edits limited to presentation layers"
